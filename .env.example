# ─────────────────────────────────────────────────────────────
# BIRD PALACE BOOKING – Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git
# ─────────────────────────────────────────────────────────────

# Your deployed URL (no trailing slash)
# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_SITE_URL=https://booking.birdpalace.be

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (email) ────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_...

# ── Google Calendar (service account) ─────────────────────────
# Paste the entire contents of your service account JSON here (as one line)
# See SETUP.md for how to create this
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Contact email ─────────────────────────────────────────────
CONTACT_EMAIL=info@birdpalace.be
